# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# sqlite runtime sidecar files (data/degree-planner.sqlite itself is committed)
data/*.sqlite-wal
data/*.sqlite-shm
data/*.sqlite-journal

# Yedion background worker: browser profile, authenticated session, raw pages, and logs.
data/yedion/worker/

# Yedion raw scraping cache: not read by the running app (already imported into
# data/degree-planner.sqlite) and fully regenerable via the yedion:* scripts.
# The merged catalog/search JSON files ARE kept tracked - they're the hard-won,
# WAF-workaround-dependent result and are worth preserving even though the DB
# already has them imported.
data/yedion/page-cache/
data/yedion/checkpoints/
data/yedion/search/page-cache/

# local dev server logs
dev-server.out.log
dev-server.err.log

.vercel
.env*
